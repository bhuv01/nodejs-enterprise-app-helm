{
  "name": "server-info",
  "version": "1.0.0",
  "description": "Enterprise-grade Node.js app that reports server time and hostname, with a live ops dashboard UI.",
  "main": "src/server.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --coverage --runInBand",
    "test:watch": "jest --watch",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "audit:prod": "npm audit --omit=dev --audit-level=high"
  },
  "keywords": [
    "nodejs",
    "express",
    "kubernetes",
    "devsecops",
    "enterprise"
  ],
  "author": "Platform Engineering",
  "license": "MIT",
  "dependencies": {
    "compression": "^1.7.4",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "nodemon": "^3.1.7",
    "supertest": "^7.0.0"
  }
}
